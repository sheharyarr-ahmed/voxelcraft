#!/usr/bin/env bash
# SPEC decision D10: single-author git history, mechanically enforced.
# Rejects any AI-attribution string in a commit message. Applies to every
# remote this repo pushes to (GitHub and the HF Space). Never bypass with
# --no-verify.
msg_file="$1"

patterns=(
  'co-authored-by:.*claude'
  'co-authored-by:.*anthropic'
  'generated with.*claude'
  'generated by.*claude'
  'noreply@anthropic\.com'
  'anthropic\.com'
  'claude code'
  '🤖'
)

for p in "${patterns[@]}"; do
  if grep -Eiq "$p" "$msg_file"; then
    echo "commit-msg hook: REJECTED — message matches AI-attribution pattern: $p" >&2
    echo "Single-author history is a locked decision (SPEC D10). Rewrite the message." >&2
    exit 1
  fi
done

exit 0
